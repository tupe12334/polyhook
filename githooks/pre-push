#!/usr/bin/env bash
set -euo pipefail

echo "Running cspell..."
if ! make spell 2>&1; then
  echo "" >&2
  echo "pre-push: spell check failed. Fix errors above or add words to .cspell.json." >&2
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "▶ Formatting sources before push…"
make format

echo "▶ Generating READMEs…"
make readme

echo "▶ Running coverage checks before push…"
make test-coverage

echo "✓ All checks passed — proceeding with push."
